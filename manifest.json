{
  "manifest_version": 3,
  "name": "Block Mailtrack",
  "version": "2.0",
  "description": "Blocks email tracking pixels from Mailtrack and other spy-pixel services in Gmail.",
  "homepage_url": "https://marvellouscode.works/block-mailtrack",
  "browser_specific_settings": {
    "gecko": {
      "id": "block-mailtrack@noads.it",
      "strict_min_version": "127.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://mail.google.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "tracker_rules",
        "enabled": true,
        "path": "rules/rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://mail.google.com/*"],
      "css": ["mtsignature.css"]
    }
  ]
}
